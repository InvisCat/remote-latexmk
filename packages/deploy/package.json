{
  "name": "@latexmk/deploy",
  "version": "0.3.0-rc.2",
  "private": true,
  "type": "module",
  "bin": {
    "latexmk-deploy": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node scripts/build.mjs && node --test test/*.test.mjs",
    "lint": "node scripts/build.mjs && node --check dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
