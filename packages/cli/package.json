{
  "name": "@latexmk/cli",
  "version": "0.4.2",
  "private": true,
  "scripts": {
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist',{recursive:true})\" && go build -trimpath -o dist/rlatexmk ./cmd/rlatexmk",
    "test": "go test ./...",
    "lint": "go vet ./...",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
