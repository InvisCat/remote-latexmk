{
  "name": "@latexmk/cli",
  "version": "0.3.0-rc.2",
  "private": true,
  "scripts": {
    "build": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && go build -trimpath -o dist/latexmk ./cmd/latexmk",
    "test": "go test ./...",
    "lint": "go vet ./...",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
