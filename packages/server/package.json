{
  "name": "@latexmk/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && go build -trimpath -o dist/latexmk-server ./cmd/server",
    "test": "go test ./...",
    "lint": "go vet ./...",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
