# Required. Use a new random value with at least 24 characters.
LATEXMK_API_TOKEN=

# The credential-free gateway accepts connections only from this machine.
# The token/state/TeX server itself stays on an internal Docker network.
# Set 0.0.0.0 only when a firewall, private LAN, VPN, or TLS proxy protects it.
LATEXMK_BIND_ADDRESS=127.0.0.1
LATEXMK_HOST_PORT=8080

# Client container. Set PROJECT_DIR to the paper directory, or to its Git root
# when the client should apply ignore rules inherited from parent directories.
LATEXMK_PROJECT_DIR=./examples/basic
LATEXMK_CLIENT_ENTRY=main.tex
LATEXMK_CLIENT_WATCH_INTERVAL=500ms
LATEXMK_CLIENT_WATCH_DEBOUNCE=500ms
LATEXMK_CLIENT_SERVER=http://server:8080
# Leave empty to reuse LATEXMK_API_TOKEN for the local Compose server.
LATEXMK_CLIENT_TOKEN=
# auto uploads discovered dependencies; all is the explicit compatibility mode.
LATEXMK_CLIENT_UPLOAD_MODE=auto
# Optional project-relative exact file list, one path per line.
LATEXMK_CLIENT_MANIFEST_FILE=
# On Linux, set these to `id -u` and `id -g` if your account is not 1000:1000.
LATEXMK_CLIENT_UID=1000
LATEXMK_CLIENT_GID=1000
LATEXMK_CLIENT_IMAGE=latexmk-client:local

# Optional HTTPS profile. The default exposes Caddy only on localhost:8443.
LATEXMK_HTTPS_BIND_ADDRESS=127.0.0.1
LATEXMK_HTTPS_PORT=8443
LATEXMK_TLS_HOST=localhost
# For the Compose client, use /etc/latexmk/certs/caddy-local-root.crt after
# copying Caddy's local root CA into ./certs as described in the README.
LATEXMK_CLIENT_CA_FILE=

# Optional image and resource overrides.
LATEXMK_SERVER_IMAGE=latexmk-server:local
LATEXMK_ENGINES=xelatex,pdflatex
LATEXMK_MEMORY_LIMIT=2g
LATEXMK_PIDS_LIMIT=192
LATEXMK_TMPFS_SIZE=768m
LATEXMK_COMPILE_TIMEOUT=5m
LATEXMK_MAX_CONCURRENT_COMPILES=1
LATEXMK_MAX_QUEUED_JOBS=12
LATEXMK_RESULT_RETENTION=168h
LATEXMK_SNAPSHOT_RETENTION=168h
LATEXMK_BLOB_RETENTION=168h

# Pin these images by digest for a reproducible production deployment.
GO_IMAGE=golang:1.26.5-bookworm
TEXLIVE_IMAGE=texlive/texlive:latest-basic
LATEXMK_CLIENT_BASE_IMAGE=debian:bookworm-slim
CADDY_IMAGE=caddy:2-alpine
